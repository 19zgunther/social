generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model emojis {
  uuid       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  created_by String    @db.Uuid
  data       String
  name       String
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
  users      users     @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model friends {
  id                                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requesting_user                      String    @db.Uuid
  requested_at                         DateTime  @db.Timestamptz(6)
  other_user                           String    @db.Uuid
  accepted                             Boolean?
  accepted_at                          DateTime? @db.Timestamptz(6)
  users_friends_other_userTousers      users     @relation("friends_other_userTousers", fields: [other_user], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_friends_requesting_userTousers users     @relation("friends_requesting_userTousers", fields: [requesting_user], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model posts {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  created_by       String             @db.Uuid
  image_id         String?            @db.Uuid
  text             String?
  data             Json?              @db.Json
  permanent        Boolean?
  users            users              @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user_post_access user_post_access[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model push_subscriptions {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String    @db.Uuid
  endpoint     String    @unique
  p256dh       String?
  created_at   DateTime? @db.Timestamptz(6)
  updated_at   DateTime? @db.Timestamptz(6)
  user_agent   String?
  last_seen_at DateTime? @db.Timestamptz(6)
  is_active    Boolean   @default(true)
  auth         String?
  users        users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model shared_feedback {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)
  created_by String   @db.Uuid
  text       String
  status     String
  image_id   String?  @db.Uuid
  users      users    @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model temp_passwords {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)
  expires_at DateTime @db.Timestamptz(6)
  was_used   Boolean
  users      users    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model thread_events {
  id                                              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at                                      DateTime  @default(now()) @db.Timestamptz(6)
  updated_at                                      DateTime  @db.Timestamptz(6)
  created_by                                      String    @db.Uuid
  name                                            String
  location                                        String?
  description                                     String?
  users_status_map                                Json      @db.Json
  starts_at                                       DateTime  @db.Timestamptz(6)
  ends_at                                         DateTime  @db.Timestamptz(6)
  background_image_id                             String?   @db.Uuid
  thread_id                                       String    @db.Uuid
  users                                           users     @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  threads_thread_events_thread_idTothreads        threads   @relation("thread_events_thread_idTothreads", fields: [thread_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  threads_threads_created_by_eventTothread_events threads[] @relation("threads_created_by_eventTothread_events")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model thread_messages {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at     DateTime  @default(now()) @db.Timestamptz(6)
  updated_at     DateTime? @db.Timestamptz(6)
  created_by     String    @db.Uuid
  parent_id      String?   @db.Uuid
  text           String?
  image_id       String?   @db.Uuid
  data           Json?     @db.Json
  post_id        String?   @db.Uuid
  root_parent_id String?   @db.Uuid
  users          users     @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model threads {
  id                                                    String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at                                            DateTime                   @default(now()) @db.Timestamptz(6)
  owner                                                 String                     @db.Uuid
  name                                                  String
  image_id                                              String?                    @db.Uuid
  created_by_event                                      String?                    @db.Uuid
  is_direct                                             Boolean?
  thread_events_thread_events_thread_idTothreads        thread_events[]            @relation("thread_events_thread_idTothreads")
  thread_events_threads_created_by_eventTothread_events thread_events?             @relation("threads_created_by_eventTothread_events", fields: [created_by_event], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                                                 users                      @relation(fields: [owner], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user_thread_access                                    user_thread_access[]
  user_thread_last_read_at                              user_thread_last_read_at[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user_post_access {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_id    String   @db.Uuid
  viewer_id  String   @db.Uuid
  created_at DateTime @db.Timestamptz(6)
  posts      posts    @relation(fields: [post_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users      users    @relation(fields: [viewer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([post_id, viewer_id])
  @@index([post_id])
  @@index([viewer_id, created_at(sort: Desc)])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user_sessions {
  user_id    String   @id @db.Uuid
  updated_at DateTime @db.Timestamptz(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user_thread_access {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  thread_id  String   @db.Uuid
  user_id    String   @db.Uuid
  created_at DateTime @db.Timestamptz(6)
  threads    threads  @relation(fields: [thread_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users      users    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user_thread_last_read_at {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  thread_id    String   @db.Uuid
  user_id      String   @db.Uuid
  last_read_at DateTime @db.Timestamptz(6)
  threads      threads  @relation(fields: [thread_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users        users    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id                                     String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username                               String                     @unique
  email                                  String?
  password_hash                          String?
  email_verified_at                      DateTime?                  @db.Timestamptz(6)
  created_at                             DateTime?                  @db.Timestamptz(6)
  profile_image_id                       String?                    @db.Uuid
  post_groups_data                       Json?                      @db.Json
  emojis                                 emojis[]
  friends_friends_other_userTousers      friends[]                  @relation("friends_other_userTousers")
  friends_friends_requesting_userTousers friends[]                  @relation("friends_requesting_userTousers")
  posts                                  posts[]
  push_subscriptions                     push_subscriptions[]
  shared_feedback                        shared_feedback[]
  temp_passwords                         temp_passwords[]
  thread_events                          thread_events[]
  thread_messages                        thread_messages[]
  threads                                threads[]
  user_post_access                       user_post_access[]
  user_sessions                          user_sessions?
  user_thread_access                     user_thread_access[]
  user_thread_last_read_at               user_thread_last_read_at[]
  webrtc_signalling                      webrtc_signalling[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model webrtc_signalling {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  thread_id       String   @db.Uuid
  call_session_id String   @db.Uuid
  from_user_id    String   @db.Uuid
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  payload         Json?
  users           users    @relation(fields: [from_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}
